<section class="dsn-bridge-tray" data-app-id="{{appId}}">
    <header class="dsn-tray-head">
        <span class="dsn-title">
            <i class="fa-solid fa-dice-d20"></i>
            {{localize "pf2e-dsn-persistent-bridge.tray.header"}}
        </span>
        <span class="dsn-tray-actions">
            {{#if showSelectAll}}
                <button type="button" class="dsn-tray-btn dsn-select-all"
                        data-action="dsn-select-all"
                        data-tooltip="{{selectAllTooltip}}">
                    <i class="fa-solid fa-object-group"></i>
                    <span>{{selectAllLabel}}</span>
                </button>
            {{/if}}
            {{#if showAccessToggle}}
                <button type="button" class="dsn-access-toggle {{#if accessLocked}}is-locked{{else}}is-unlocked{{/if}}"
                        data-action="dsn-toggle-access"
                        data-tooltip="{{accessTooltip}}">
                    <i class="fa-solid {{accessIcon}}"></i>
                    <span class="dsn-access-label">{{accessLabel}}</span>
                </button>
            {{/if}}
            <button type="button" class="dsn-perf-btn perf-{{perfCurrent}}"
                    data-action="dsn-cycle-perf"
                    data-tooltip="{{perfTooltip}}">
                <i class="fa-solid fa-bolt"></i>
                <span class="dsn-perf-label">{{perfLabel}}</span>
            </button>
        </span>
    </header>

    {{#if disabled}}
        <div class="dsn-banner dsn-banner-warn">
            <i class="fa-solid fa-circle-exclamation"></i>
            {{localize "pf2e-dsn-persistent-bridge.tray.disabledBanner"}}
            {{#if disabledReason}}<br><span class="dsn-disabled-reason">{{disabledReason}}</span>{{/if}}
        </div>
    {{else if secretSkipped}}
        <div class="dsn-banner dsn-banner-secret">
            <i class="fa-solid fa-eye-slash"></i>
            {{localize "pf2e-dsn-persistent-bridge.tray.secretBanner"}}
        </div>
    {{else if ceremonialGhost}}
        <div class="dsn-banner dsn-banner-ghost">
            <i class="fa-solid fa-ghost"></i>
            {{localize "pf2e-dsn-persistent-bridge.tray.ceremonialBanner"}}
        </div>
    {{else if isEmpty}}
        <div class="dsn-banner">{{localize "pf2e-dsn-persistent-bridge.tray.noDice"}}</div>
    {{else}}
        <div class="dsn-slots">
            {{#each slots}}
                <div class="dsn-slot state-{{state}}" data-slot-key="{{key}}" data-faces="{{faces}}">
                    <div class="dsn-slot-tag">d{{faces}}</div>
                    <div class="dsn-slot-face">
                        {{#if value}}
                            <span class="dsn-slot-value{{#if hidden}} dsn-slot-value-hidden{{/if}}">{{displayValue}}</span>
                        {{else}}
                            <span class="dsn-slot-placeholder">
                                <i class="fa-solid fa-circle-notch fa-spin"></i>
                            </span>
                        {{/if}}
                    </div>
                </div>
            {{/each}}
        </div>
        <p class="dsn-hint">{{localize "pf2e-dsn-persistent-bridge.tray.hint"}}</p>
    {{/if}}
</section>
