{
  "id": "pf2e-dsn-persistent-bridge",
  "title": "PF2e \u00d7 DSN Persistent Dice Bridge",
  "description": "Use Dice So Nice persistent dice you physically roll on the canvas as the input for PF2e check / damage / reroll dialogs.",
  "version": "0.2.4",
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "authors": [
    {
      "name": "takaqiao",
      "url": "https://github.com/takaqiao"
    }
  ],
  "license": "MIT",
  "esmodules": [
    "scripts/main.js"
  ],
  "styles": [
    "styles/dsn-bridge.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "cn",
      "name": "\u4e2d\u6587 (\u7b80\u4f53)",
      "path": "lang/zh-CN.json"
    },
    {
      "lang": "zh-CN",
      "name": "\u4e2d\u6587 (\u7b80\u4f53)",
      "path": "lang/zh-CN.json"
    }
  ],
  "relationships": {
    "systems": [
      {
        "id": "pf2e",
        "type": "system",
        "compatibility": {
          "verified": "7"
        }
      }
    ],
    "requires": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "manifest": "https://github.com/ruipin/fvtt-lib-wrapper/releases/latest/download/module.json",
        "compatibility": {
          "minimum": "1.13"
        }
      }
    ],
    "recommends": [
      {
        "id": "dice-so-nice",
        "type": "module",
        "reason": "Provides persistent dice physics on the canvas; without it this module silently disables itself."
      }
    ]
  },
  "socket": true,
  "url": "https://github.com/takaqiao/pf2e-dsn-persistent-bridge",
  "manifest": "https://github.com/takaqiao/pf2e-dsn-persistent-bridge/releases/latest/download/module.json",
  "download": "https://github.com/takaqiao/pf2e-dsn-persistent-bridge/releases/download/v0.2.4/module.zip",
  "bugs": "https://github.com/takaqiao/pf2e-dsn-persistent-bridge/issues",
  "readme": "https://github.com/takaqiao/pf2e-dsn-persistent-bridge#readme",
  "changelog": "https://github.com/takaqiao/pf2e-dsn-persistent-bridge/blob/main/CHANGELOG.md"
}
